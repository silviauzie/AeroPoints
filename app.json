{
  "expo": {
    "name": "AeroPoints",
    "slug": "aeropoints",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/AeropointsAppIcon.png",
    "scheme": "aeropoints",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/AeropointsAppIcon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/AeropointsAppIcon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/WhiteLogoForReactProject.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#CD0100",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
